# REST API server
F_SERVER_HOST=127.0.0.1
F_SERVER_PORT=18080

# OCPP WebSocket server powered by ocpp-go
# Charger URL locally: ws://127.0.0.1:18081/<charger_id>
OCPP_LISTEN_PORT=18081
OCPP_LISTEN_PATH=/{ws}

LOG_LEVEL=debug
API_KEY=testkey

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ocppgo
DB_USER=ocppgodbadmin
DB_PASSWORD=change-me
DB_SSLMODE=disable

# Optional single URL alternative
# DATABASE_URL=postgres://ocppgodbadmin:change-me@127.0.0.1:5432/ocppgo?sslmode=disable
