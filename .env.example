# REST API
F_SERVER_HOST=127.0.0.1
F_SERVER_PORT=18080

# OCPP central system
OCPP_LISTEN_PORT=18081
OCPP_LISTEN_PATH=/{ws}

# API auth
API_KEY=testkey
APIAUTHKEY=replace-me

# Logging
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ocppgo
DB_USER=ocppgodbadmin
DB_PASSWORD=replace-me
DB_SSLMODE=disable

# Main CMS hooks
MAIN_CMS_START_TXN_HOOK_URL=https://be.cms.ocpp.transev.site/users/checkstartresponse
MAIN_CMS_COMPLETED_TXN_URL=https://be.cms.ocpp.transev.site/users/deductcalculate

# Single-session CMS hooks
SINGLE_SESSION_START_TXN_HOOK_URL=
SINGLE_SESSION_COMPLETED_TXN_URL=

# Charger directory endpoint
APICHARGERDATA=
CHARGER_DATA_CACHE_TTL_SECONDS=7200

# Local mock hooks
MOCK_HOOK_ADDR=127.0.0.1:19090
MOCK_START_MAX_KWH=7.5
MOCK_CHARGER_IDS=CP-REG-CORE-001,CP-REG-SINGLE-001,CP-REG-LIMIT-001,CP-REG-OFFLINE-001
